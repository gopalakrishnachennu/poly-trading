# Non-secret local staging defaults. This file intentionally contains no
# credentials and cannot enable trading.
POLY_TERMINAL_MODE=READ_ONLY
POLY_TERMINAL_NO_TRADE=true
POLY_TERMINAL_BIND=127.0.0.1
POLY_TERMINAL_PORT=8088
NEXT_PUBLIC_TERMINAL_API_URL=http://localhost:8088

# Optional durable MinIO archive fixture. Replace these placeholders in your
# shell or an untracked .env file before enabling the durable profile. Never
# commit real credentials. These values are not used by the read-only API.
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=poly-terminal-archive
